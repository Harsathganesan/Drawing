{
  "name": "drawing-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run frontend\" \"npm run backend\"",
    "frontend": "npm start --prefix frontend",
    "backend": "npm start --prefix Backend",
